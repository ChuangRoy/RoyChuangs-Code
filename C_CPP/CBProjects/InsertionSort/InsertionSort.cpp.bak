#include <iostream>
#include <ctime>
#include <cstdlib>
using namespace std;

int l[5] = {60, 50, 44, 82, 55};

void random_list () {
    srand (time(NULL));
    for (int i = 0; i < 5; i++) {
        l[i] = rand();
        // cout << l[i] << endl;
    }
}

void insert_into_list (int index) {
	for (int i = 5; i > index; i++)
}

int main () {
    // random_list();
    int last_index = 0;
    bool sort_finish = 0;
    while (!sort_finish) {
        target_index = last_index + 1;
        for (int i = 0; i <= last_index; i++) {
            if (last_index == 0) {
                if (l[target_index] < l[last_index])
                    insert_into_list(0);
                else
                    insert_into_list(1);
            }
        }

    }


}
